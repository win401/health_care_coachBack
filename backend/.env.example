# backend/.env 로 복사해서 사용하세요 (backend/.env는 .gitignore에 포함되어 커밋되지 않습니다).
# 값을 비워두면 자동으로 규칙 기반 fallback으로 동작합니다 (에러 없이 안전하게 동작).

# 세션 음성 메모 요약 / 리포트 생성에 사용할 OpenAI API 키
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 음성 녹음 -> 텍스트 변환(STT)에 사용할 Whisper 모델
# 주의: STT는 규칙 기반 fallback이 없습니다. 키가 없으면 녹음 자동 요약 대신
# 트레이너가 텍스트로 직접 입력하는 방식으로 동작합니다.
OPENAI_STT_MODEL=whisper-1

# 자세 분석에 사용할 YOLO pose 모델 (ultralytics)
# 값을 비워두면 기본값 yolov8n-pose.pt 사용, ultralytics 미설치/모델 다운로드 실패 시 자동 fallback
YOLO_POSE_MODEL=yolov8n-pose.pt

# ---- 배포(Railway 등) 환경 전용 설정. 로컬 개발에서는 비워둬도 됩니다. ----

# Next.js 프론트가 배포된 실제 도메인(콤마로 여러 개 가능). 로컬 기본값은 http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# 배포는 HTTPS이므로 1로 설정해서 인증 쿠키에 Secure 플래그를 붙입니다. 로컬 http 개발은 0(기본값) 유지.
COOKIE_SECURE=0

# SQLite DB 파일 경로. Railway에서는 마운트한 볼륨 경로로 지정해야 재배포해도 데이터가 유지됩니다.
# 예: /data/fitnote_trainer.db
FITNOTE_DB_PATH=

# 업로드된 사진/음성 파일 저장 경로. 위와 같은 이유로 볼륨 경로 지정 권장.
# 예: /data/uploads
FITNOTE_UPLOAD_DIR=
